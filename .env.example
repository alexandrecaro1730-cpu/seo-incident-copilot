# Business objective: keep credentials out of the repository and out of prompts.
# Technical objective: load sensitive runtime configuration from environment variables.

SLACK_WEBHOOK_URL=
SEO_COPILOT_ENV=local
# Current default: fixture mode for deterministic case-study testing.
LLM_PROVIDER=fixture

# Optional future live model configuration.
CHEAP_MODEL_NAME=
MIDDLE_MODEL_NAME=
EXPENSIVE_MODEL_NAME=

# Optional provider credentials. Leave empty in GitHub.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
